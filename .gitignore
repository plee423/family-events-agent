__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# Cache and output (don't commit these)
cache/*.json
output/*.ics
logs/*.log

# Keep directory structure
!cache/.gitkeep
!output/.gitkeep
!logs/.gitkeep

# Geocode cache is committed to warm CI runs — persists across Actions runs
!cache/geocode_cache.json
